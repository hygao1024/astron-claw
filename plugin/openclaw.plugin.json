{
  "id": "astron-claw",
  "name": "astron-claw",
  "description": "AstronClaw channel plugin - connects chat clients via bridge server to OpenClaw.",
  "version": "2.0.0",
  "type": "channel",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Whether the AstronClaw channel is enabled",
        "default": true
      },
      "name": {
        "type": "string",
        "description": "Display name for this channel account",
        "default": "AstronClaw"
      },
      "bridge": {
        "type": "object",
        "description": "Bridge server connection settings",
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "description": "WebSocket URL of the bridge server",
            "default": "ws://localhost:8765/bridge/bot"
          },
          "token": {
            "type": "string",
            "description": "Authentication token for the bridge server"
          }
        },
        "required": ["url"]
      },
      "allowFrom": {
        "type": "array",
        "description": "Sender whitelist for DM. Use [\"*\"] to allow all senders.",
        "items": {
          "type": "string"
        },
        "default": ["*"]
      },
      "media": {
        "type": "object",
        "description": "Media handling settings",
        "additionalProperties": false,
        "properties": {
          "maxSize": {
            "type": "number",
            "description": "Maximum media file size in bytes",
            "default": 52428800
          },
          "allowedTypes": {
            "type": "array",
            "description": "Allowed MIME type patterns for media",
            "items": {
              "type": "string"
            },
            "default": [
              "image/*",
              "audio/*",
              "video/*",
              "application/pdf",
              "application/zip",
              "text/plain",
              "application/octet-stream"
            ]
          }
        }
      },
      "retry": {
        "type": "object",
        "description": "Reconnection retry settings",
        "additionalProperties": false,
        "properties": {
          "baseMs": {
            "type": "number",
            "description": "Initial retry delay in milliseconds",
            "default": 1000
          },
          "maxMs": {
            "type": "number",
            "description": "Maximum retry delay in milliseconds",
            "default": 60000
          },
          "maxAttempts": {
            "type": "number",
            "description": "Maximum number of retry attempts (0 = unlimited)",
            "default": 0
          }
        }
      }
    }
  }
}
